// prisma/schema.prisma
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  password   String
  phone      String?
  avatar     String?
  role       String   @default("CUSTOMER")
  isActive   Boolean  @default(true)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  addresses     Address[]
  cart          Cart?
  wishlists     Wishlist[]
  orders        Order[]
  reviews       Review[]
  notifications Notification[]
  payments      Payment[]

  @@map("users")
}

model Address {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  provinceId   String
  provinceName String

  wardId   String
  wardName String

  detail String

  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@map("addresses")
}

model Province {
  id    String @id @default(uuid())
  code  String @unique
  name  String
  wards Ward[]

  @@map("provinces")
}

model Ward {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  type       String
  provinceId String
  province   Province @relation(fields: [provinceId], references: [id])

  @@map("wards")
}

model Brand {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  logo        String?
  description String?
  isActive    Boolean @default(true)

  products Product[]

  @@map("brands")
}

model Category {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  image    String?
  parentId String?
  level    Int     @default(0)
  isActive Boolean @default(true)

  products Product[]

  // Self-referential relationship (Parent - Children)
  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")

  @@map("categories")
}

model Product {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  description      String?
  shortDescription String?
  basePrice        Decimal
  salePrice        Decimal?
  stock            Int
  images           String[]
  specifications   Json?
  warrantyInfo     String?
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  brandId    String?
  brand      Brand?   @relation(fields: [brandId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  productVariants ProductVariant[]
  wishlistItems   WishlistItem[]
  reviews         Review[]

  @@map("products")
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  sku       String   @unique
  color     String?
  storage   String?
  ram       String?
  price     Decimal
  stock     Int
  images    String[]

  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  promotion     Promotion?

  @@map("product_variants")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id])
  cartItems CartItem[]

  @@map("carts")
}

model CartItem {
  id               String         @id @default(uuid())
  cartId           String
  cart             Cart           @relation(fields: [cartId], references: [id])
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  quantity         Int

  @@map("cart_items")
}

model Wishlist {
  id            String         @id @default(uuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id])
  wishlistItems WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(uuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id])

  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  createdAt DateTime @default(now())
  product   Product? @relation(fields: [productId], references: [id])
  productId String?

  @@map("wishlist_items")
}

model Order {
  id             String   @id @default(uuid())
  orderCode      String   @unique
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  totalAmount    Decimal
  shippingFee    Decimal  @default(0)
  discountAmount Decimal  @default(0)
  finalAmount    Decimal
  status         String   @default("PENDING")
  paymentStatus  String   @default("PENDING")
  addressId      String
  address        Address  @relation(fields: [addressId], references: [id])
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orderItems OrderItem[]
  payments   Payment[]

  @@map("orders")
}

model OrderItem {
  id               String         @id @default(uuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id])
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  productName      String
  variantInfo      String
  quantity         Int
  price            Decimal
  totalPrice       Decimal

  @@map("order_items")
}

model Payment {
  id              String    @id @default(uuid())
  orderId         String?
  order           Order?    @relation(fields: [orderId], references: [id])
  paymentIntentId String?   @unique
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  method          String    @default("COD")
  transactionId   String?
  amount          Decimal
  status          String    @default("PENDING")
  paidAt          DateTime?
  cartSnapshot    Json?
  createdAt       DateTime  @default(now())

  @@map("payments")
}

model Coupon {
  id                   String   @id @default(uuid())
  code                 String   @unique
  discountValue        Decimal
  description          String?
  discountType         String   @default("PERCENTAGE")
  minOrderAmount       Decimal?
  maxDiscount          Decimal?
  validFrom            DateTime
  validTo              DateTime
  usageLimit           Int?
  usedCount            Int      @default(0)
  isActive             Boolean  @default(true)
  isPublic             Boolean  @default(true)
  applicableProductIds Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("coupons")
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  rating     Int      @default(5)
  comment    String?
  images     String[]
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("reviews")
}

model ShippingMethod {
  id            String  @id @default(uuid())
  name          String
  fee           Decimal
  estimatedDays Int
  isActive      Boolean @default(true)

  @@map("shipping_methods")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Promotion {
  id          String  @id @default(uuid())
  name        String
  description String?

  discountValue Decimal
  discountType  String  @default("PERCENTAGE")

  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)

  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productVariantId])
  @@map("promotions")
}
